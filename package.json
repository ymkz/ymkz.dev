{
  "name": "ymkz.dev",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "25.9.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "wrangler dev --port=3000",
    "lint": "biome check",
    "format": "biome check --write",
    "analyze": "knip",
    "update": "pnpm update --latest --interactive"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "knip": "catalog:",
    "wrangler": "catalog:"
  }
}
